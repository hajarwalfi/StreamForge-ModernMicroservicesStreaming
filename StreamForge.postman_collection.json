          "name": "1. Create Video - Inception",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Inception\",\n    \"description\": \"A thief who steals corporate secrets through the use of dream-sharing technology is given the inverse task of planting an idea into the mind of a C.E.O.\",\n    \"thumbnailUrl\": \"https://m.media-amazon.com/images/I/51GmVsBz7iL._AC_.jpg\",\n    \"trailerUrl\": \"https://www.youtube.com/embed/YoHD9XEInc0\",\n    \"duration\": 148,\n    \"releaseYear\": 2010,\n    \"type\": \"FILM\",\n    \"category\": \"SCIENCE_FICTION\",\n    \"rating\": 8.8,\n    \"director\": \"Christopher Nolan\",\n    \"cast\": \"Leonardo DiCaprio, Joseph Gordon-Levitt, Elliot Page, Tom Hardy\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/videos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "videos"]
            }
          }
        },
